        <mxCell id="PQf7IsmfZN-XSk3G28lu-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Skills&lt;/h1&gt;&lt;p&gt;Se listan los skills necesarios para utilizaicón de la plataforma bajo un escenario de que Infra solamente entregue la capacidad aprovisiona&lt;/p&gt;&lt;table style=&quot;border-collapse:&lt;br/&gt; collapse;width:815pt&quot; width=&quot;1085&quot; cellspacing=&quot;0&quot; cellpadding=&quot;0&quot; border=&quot;0&quot;&gt; &lt;colgroup&gt;&lt;col style=&quot;mso-width-source:userset;mso-width-alt:4677;width:101pt&quot; width=&quot;134&quot;&gt;&lt;/colgroup&gt; &lt;colgroup&gt;&lt;col style=&quot;mso-width-source:userset;mso-width-alt:11124;width:239pt&quot; width=&quot;319&quot;&gt;&lt;/colgroup&gt; &lt;colgroup&gt;&lt;col style=&quot;mso-width-source:userset;mso-width-alt:3467;width:75pt&quot; width=&quot;99&quot;&gt;&lt;/colgroup&gt; &lt;colgroup&gt;&lt;col style=&quot;mso-width-source:userset;mso-width-alt:18618;width:400pt&quot; width=&quot;533&quot;&gt;&lt;/colgroup&gt; &lt;tbody&gt;&lt;tr style=&quot;mso-height-source:userset;height:18.0pt&quot; height=&quot;24&quot;&gt;  &lt;td style=&quot;height:18.0pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl65&quot; height=&quot;24&quot;&gt;Área&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl65&quot;&gt;Skill clave&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl65&quot;&gt;Nivel requerido&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl65&quot;&gt;Para qué lo necesitan&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Arquitectura&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Data Platform Architect&lt;br&gt;  (Lakehouse)&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Diseñar medallion&lt;br&gt;  (Bronze/Silver/Gold), separar ETL vs BI, definir estrategia UC + Purview&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Ingeniería&lt;br&gt;  de Datos&lt;br&gt;&lt;br&gt;&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Databricks Data Engineer&lt;br&gt;  (Spark/Delta)&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Implementar pipelines,&lt;br&gt;  notebooks, jobs, optimización Delta&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Modelado&lt;br&gt;  de Datos&lt;br&gt;&lt;br&gt;&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Data Modeler (Kimball +&lt;br&gt;  Lakehouse)&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Definir grano, dimensiones,&lt;br&gt;  tablas GOLD optimizadas para Tableau&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;SQL&lt;br&gt;  &amp;amp; Performance&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;SQL avanzado + Optimización&lt;br&gt;  Delta&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Crear vistas/materializaciones&lt;br&gt;  para Tableau, tuning de consultas&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Gobierno&lt;br&gt;  de Datos&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Unity Catalog Specialist&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio–Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Definir catálogos, esquemas,&lt;br&gt;  políticas, RBAC, data masking&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Gobierno&lt;br&gt;  Empresarial&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Purview Governance Lead&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Configurar escaneos, linaje&lt;br&gt;  cross-plataforma, Business Glossary&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Seguridad&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Data Security / IAM Azure&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio–Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;RBAC en Azure + Databricks +&lt;br&gt;  Purview&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Orquestación&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Azure Data Factory Specialist&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Ingesta y orquestación de&lt;br&gt;  pipelines&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Data&lt;br&gt;  Quality&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Data Quality Analyst&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Definir reglas y monitoreo de&lt;br&gt;  calidad (Purview / notebooks)&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Tableau&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Tableau Data Engineer / BI Dev&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio–Alto&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Diseñar fuentes optimizadas,&lt;br&gt;  manejar extractos, tuning de queries&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;DevOps&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;CI/CD para Databricks&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Versionamiento, repos, promoción&lt;br&gt;  Dev→Prod&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&quot;height:14.5pt&quot; height=&quot;19&quot;&gt;  &lt;td style=&quot;height:14.5pt;width:101pt&quot; width=&quot;134&quot; class=&quot;xl66&quot; height=&quot;19&quot;&gt;Gestión&lt;/td&gt;  &lt;td style=&quot;width:239pt&quot; width=&quot;319&quot; class=&quot;xl66&quot;&gt;Data Delivery Lead&lt;/td&gt;  &lt;td style=&quot;width:75pt&quot; width=&quot;99&quot; class=&quot;xl66&quot;&gt;Medio&lt;/td&gt;  &lt;td style=&quot;width:400pt&quot; width=&quot;533&quot; class=&quot;xl66&quot;&gt;Roadmap, coordinación técnica,&lt;br&gt;  gobierno operativo&lt;/td&gt; &lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="124" y="3344" width="1161.5" height="508" as="geometry" />
        </mxCell>
        <mxCell id="GDsNWkG0j_jzanI2DjEN-1" value="&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;h1 data-end=&quot;193&quot; data-start=&quot;142&quot;&gt;Descripción Arquitectura To-Be – Azure Databricks&lt;/h1&gt;&lt;p data-end=&quot;397&quot; data-start=&quot;195&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;La arquitectura objetivo se basa en &lt;/span&gt;&lt;strong style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;262&quot; data-start=&quot;232&quot;&gt;Azure Databricks Lakehouse&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; como plataforma escalable de analítica, consolidando ingestión, transformación, almacenamiento y consumo analítico sobre Azure Data Lake Storage Gen2 bajo un modelo desacoplado y gobernado.&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;397&quot; data-start=&quot;195&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Componentes principales:&lt;/span&gt;&lt;/p&gt;&lt;h2 data-end=&quot;501&quot; data-start=&quot;486&quot;&gt;Orquestación&lt;/h2&gt;&lt;p data-end=&quot;688&quot; data-start=&quot;503&quot;&gt;La ingesta de datos desde Salesforce, Zoom, Sage, Jira y otras fuentes se gestiona mediante &lt;strong data-end=&quot;623&quot; data-start=&quot;595&quot;&gt;Azure Data Factory (ADF)&lt;/strong&gt;, permitiendo cargas incrementales y controladas hacia ADLS Gen2.&lt;/p&gt;&lt;p data-end=&quot;789&quot; data-start=&quot;690&quot;&gt;ADF orquesta procesos EL (Extract &amp;amp; Load), mientras que la transformación se ejecuta en Databricks.&lt;/p&gt;&lt;p data-end=&quot;789&quot; data-start=&quot;690&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h2 data-end=&quot;841&quot; data-start=&quot;796&quot;&gt;Persistencia – Azure Data Lake (ADLS Gen2)&lt;/h2&gt;&lt;p data-end=&quot;938&quot; data-start=&quot;843&quot;&gt;Los datos se almacenan en formato &lt;strong data-end=&quot;907&quot; data-start=&quot;877&quot;&gt;Delta Parquet (Delta Lake)&lt;/strong&gt; bajo una estructura por capas&lt;/p&gt;&lt;ul data-end=&quot;1123&quot; data-start=&quot;940&quot;&gt;&lt;li&gt;&lt;strong data-end=&quot;953&quot; data-start=&quot;942&quot;&gt;Bronze:&lt;/strong&gt; datos crudos, sin transformación.&lt;/li&gt;&lt;li data-end=&quot;1048&quot; data-start=&quot;988&quot;&gt;&lt;p data-end=&quot;1048&quot; data-start=&quot;990&quot;&gt;&lt;strong data-end=&quot;1001&quot; data-start=&quot;990&quot;&gt;Silver:&lt;/strong&gt; datos estandarizados, armonizados y validados.&lt;/p&gt;&lt;/li&gt;&lt;li data-end=&quot;1123&quot; data-start=&quot;1049&quot;&gt;&lt;p data-end=&quot;1123&quot; data-start=&quot;1051&quot;&gt;&lt;strong data-end=&quot;1060&quot; data-start=&quot;1051&quot;&gt;Gold:&lt;/strong&gt; modelos dimensionales orientados a KPIs y análisis de negocio.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p data-end=&quot;789&quot; data-start=&quot;690&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Se habilita almacenamiento transaccional (ACID), versionado (Time Travel) y optimización de rendimiento mediante Delta Lake.&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;789&quot; data-start=&quot;690&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;h2 data-end=&quot;1273&quot; data-start=&quot;1256&quot;&gt;Transformación&lt;/h2&gt;&lt;p data-end=&quot;1313&quot; data-start=&quot;1275&quot;&gt;La transformación se realiza mediante:&lt;/p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1345&quot; data-start=&quot;1317&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1345&quot; data-start=&quot;1317&quot;&gt;Azure Databricks (Spark)&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Notebooks -&amp;nbsp;&lt;/span&gt;Jobs automatizados&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SQL Warehouse&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/span&gt;&lt;p data-end=&quot;789&quot; data-start=&quot;690&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Aplicando reglas de calidad, estandarización y lógica de negocio progresivamente desde Silver hasta Gold.&lt;/span&gt;&lt;/p&gt;&lt;p data-end=&quot;789&quot; data-start=&quot;690&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;&lt;h2 data-end=&quot;1533&quot; data-start=&quot;1508&quot;&gt;Persistencia Analítica&lt;/h2&gt;&lt;p data-end=&quot;1577&quot; data-start=&quot;1535&quot;&gt;El consumo analítico se habilita mediante:&lt;/p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1609&quot; data-start=&quot;1581&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1609&quot; data-start=&quot;1581&quot;&gt;Databricks SQL Warehouse&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Endpoints SQL&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Vistas optimizadas en la capa Gold&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/span&gt;&lt;p data-end=&quot;1765&quot; data-start=&quot;1664&quot;&gt;Esto permite realizar consultas SQL optimizadas sobre la capa Gold con separación de cómputo para BI.&lt;/p&gt;&lt;p data-end=&quot;1765&quot; data-start=&quot;1664&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h2 data-end=&quot;1812&quot; data-start=&quot;1772&quot;&gt;Capa Predictiva (opcional y a futuro)&lt;/h2&gt;&lt;p data-end=&quot;1825&quot; data-start=&quot;1814&quot;&gt;Se integra:&lt;/p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1860&quot; data-start=&quot;1829&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;1860&quot; data-start=&quot;1829&quot;&gt;Databricks Machine Learning&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Modelos avanzados en Spark&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Integración con MLflow&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/span&gt;&lt;p data-end=&quot;2019&quot; data-start=&quot;1932&quot;&gt;Preparando la plataforma para analítica predictiva y modelos de IA sobre datos curados.&lt;/p&gt;&lt;p data-end=&quot;2019&quot; data-start=&quot;1932&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h2 data-end=&quot;2041&quot; data-start=&quot;2026&quot;&gt;Presentación&lt;/h2&gt;&lt;p data-end=&quot;2191&quot; data-start=&quot;2043&quot;&gt;La capa semántica se expone a herramientas de visualización como &lt;strong data-end=&quot;2119&quot; data-start=&quot;2108&quot;&gt;Tableau&lt;/strong&gt; mediante endpoints SQL de Databricks&lt;/p&gt;&lt;p data-end=&quot;2191&quot; data-start=&quot;2043&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;h1 data-end=&quot;2222&quot; data-start=&quot;2198&quot;&gt;Gobernanza y Seguridad&lt;/h1&gt;&lt;p data-end=&quot;2250&quot; data-start=&quot;2224&quot;&gt;La arquitectura incorpora:&lt;/p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2276&quot; data-start=&quot;2254&quot;&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2276&quot; data-start=&quot;2254&quot;&gt;Microsoft Entra ID&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; para control de acceso&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2321&quot; data-start=&quot;2302&quot;&gt;Azure Key Vault&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; para manejo de secretos&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2365&quot; data-start=&quot;2348&quot;&gt;Unity Catalog&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; para gobierno centralizado, linaje y control de permisos&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2458&quot; data-start=&quot;2425&quot;&gt;Azure Monitor y Log Analytics&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; para observabilidad&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2506&quot; data-start=&quot;2481&quot;&gt;Azure Cost Management&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; para control financiero&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot; data-end=&quot;2549&quot; data-start=&quot;2533&quot;&gt;Azure DevOps&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; para versionamiento y gobierno del código&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;h1 data-end=&quot;2616&quot; data-start=&quot;2598&quot;&gt;Beneficios Clave&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Arquitectura Lakehouse escalable y desacoplada&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Alto rendimiento para procesamiento masivo (Spark)&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Separación de almacenamiento y cómputo&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Preparación nativa para Data Science y Machine Learning&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Flexibilidad para múltiples cargas de trabajo analíticas&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Gobierno avanzado con Unity Catalog&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ul data-end=&quot;2915&quot; data-start=&quot;2618&quot;&gt;&lt;br&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/span&gt;&lt;/blockquote&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="74" y="1257" width="1349" height="1439" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
